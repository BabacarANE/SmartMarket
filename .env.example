# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=smartmarket
POSTGRES_PASSWORD=changeme
POSTGRES_DB=smartmarket_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Airflow ─────────────────────────────────────────────────────────
AIRFLOW_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme

# ─── MLflow ──────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=/mlruns

# ─── APIs externes ───────────────────────────────────────────────────
# France Travail — https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=your_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret

# Adzuna — https://developer.adzuna.com
ADZUNA_APP_ID=your_app_id
ADZUNA_API_KEY=your_api_key

# ─── FastAPI ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
